{
  "name": "@pando/datatable-contracts",
  "version": "0.1.1",
  "description": "Type definitions and service interfaces for the Pando DataTable package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
