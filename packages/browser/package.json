{
  "name": "@pando-codes/datatable-browser",
  "version": "0.1.1",
  "description": "Browser-native storage adapters for the Pando DataTable package",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pando-codes/datatable-contracts": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^29.0.2",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
